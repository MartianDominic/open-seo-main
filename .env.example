# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------
NODE_ENV=development

# Auth mode:
# - cloudflare_access: validate Cloudflare Access JWTs (recommended for CF deploys)
# - local_noauth: local trusted mode with injected admin user (admin@localhost)
# - hosted: Better Auth email/password + organization mode
# Defaults to cloudflare_access when unset.
AUTH_MODE=local_noauth

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/open_seo

# Points at AI-Writer's `alwrity` PostgreSQL database on the shared postgres
# instance. Used by open-seo-main for per-client (X-Client-ID) validation (AUTH-03).
ALWRITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alwrity

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Better Auth (required when AUTH_MODE=hosted)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Cloudflare Access (required when AUTH_MODE=cloudflare_access)
# -----------------------------------------------------------------------------
TEAM_DOMAIN=
POLICY_AUD=

# -----------------------------------------------------------------------------
# PostHog analytics (optional)
# -----------------------------------------------------------------------------
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=

# -----------------------------------------------------------------------------
# DataForSEO API (required for SEO audits)
# Base64-encoded login:password
# -----------------------------------------------------------------------------
DATAFORSEO_API_KEY=

# -----------------------------------------------------------------------------
# Loops.so email (required when AUTH_MODE=hosted)
# -----------------------------------------------------------------------------
LOOPS_API_KEY=
LOOPS_TRANSACTIONAL_VERIFY_EMAIL_ID=
LOOPS_TRANSACTIONAL_RESET_PASSWORD_ID=

# -----------------------------------------------------------------------------
# Autumn billing (optional)
# -----------------------------------------------------------------------------
AUTUMN_SECRET_KEY=

# -----------------------------------------------------------------------------
# Optional server settings
# -----------------------------------------------------------------------------
# PORT=3001
# ALLOWED_HOST=yourdomain.com
