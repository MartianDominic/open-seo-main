# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Clerk publishable key - decodes to JWKS URL for JWT verification
CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/open_seo

# Points at AI-Writer's `alwrity` PostgreSQL database on the shared postgres
# instance. Used by open-seo-main for per-client (X-Client-ID) validation (AUTH-03).
ALWRITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alwrity

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# PostHog analytics (optional)
# -----------------------------------------------------------------------------
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=

# -----------------------------------------------------------------------------
# DataForSEO API (required for SEO audits)
# Base64-encoded login:password
# -----------------------------------------------------------------------------
DATAFORSEO_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic API (optional - for AI business information extraction)
# Get your API key from https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google AI API (optional - for Lithuanian proposal generation)
# Get your API key from https://ai.google.dev/
# Uses Gemini 1.5 Pro for proposal content generation
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Autumn billing (optional)
# -----------------------------------------------------------------------------
AUTUMN_SECRET_KEY=

# -----------------------------------------------------------------------------
# Dokobit E-Signature (optional - for proposal signing)
# Get your API credentials from https://www.dokobit.com/
# Provides Smart-ID and Mobile-ID signing for Baltic countries
# -----------------------------------------------------------------------------
DOKOBIT_ACCESS_TOKEN=

# Salt for hashing personal codes (GDPR compliance)
# Generate with: openssl rand -hex 32
PERSONAL_CODE_SALT=

# -----------------------------------------------------------------------------
# Stripe (optional - for proposal payments)
# Get your API keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Application URL (used for Stripe redirect URLs)
APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Optional server settings
# -----------------------------------------------------------------------------
# PORT=3001
# ALLOWED_HOST=yourdomain.com
