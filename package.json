{
  "name": "open-seo",
  "private": true,
  "sideEffects": false,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "AUTH_MODE=local_noauth vite dev",
    "dev:agents": "mkdir -p .logs && portless run vite dev 2>&1 | tee .logs/dev-server.log",
    "dev:agents:force": "mkdir -p .logs && portless --force run vite dev 2>&1 | tee .logs/dev-server.log",
    "build": "vite build && tsc --noEmit",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --type-aware --fix",
    "preview": "npm run build && vite preview --port 3001",
    "deploy": "echo 'deploy handled by CI/CD in Phase 5'",
    "types:check": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier . --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate",
    "knip": "knip",
    "release:notes": "node scripts/release-notes.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=dot",
    "billing:backlinks": "tsx scripts/backlinks-cost-profile.ts",
    "ci:check": "prettier --check . && knip && tsc --noEmit && oxlint . --type-aware"
  },
  "dependencies": {
    "@every-app/sdk": "^0.1.14",
    "@noble/ciphers": "2.1.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/nitro-v2-vite-plugin": "1.154.9",
    "@tanstack/query-core": "^5.90.9",
    "@tanstack/react-form": "^1.25.0",
    "@tanstack/react-query": "^5.90.9",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-table": "^8.21.3",
    "autumn-js": "^1.1.7",
    "bullmq": "5.74.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "daisyui": "^5.5.5",
    "dataforseo-client": "^2.0.19",
    "drizzle-orm": "^0.44.4",
    "fast-xml-parser": "^5.4.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "ioredis": "5.10.1",
    "jose": "^6.0.12",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "pg": "8.20.0",
    "posthog-js": "^1.363.5",
    "posthog-node": "^5.28.5",
    "puppeteer": "^24.41.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "remeda": "^2.33.6",
    "resend": "^6.12.0",
    "robots-parser": "^3.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.16",
    "tailwindcss-animate": "^1.0.7",
    "tldts": "^7.0.25",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.18.13",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.6.0",
    "drizzle-kit": "^0.31.4",
    "knip": "^5.66.4",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "portless": "^0.5.2",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
